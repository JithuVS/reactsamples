import React, { useState } from 'react';
import {
  Box,
  Typography,
  IconButton,
  Button,
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  TextField,
  Select,
  MenuItem,
  FormControl,
  InputLabel,
  Stack,
  List,
  ListItem,
  ListItemIcon,
  ListItemText,
  ListItemSecondaryAction,
  Paper
} from '@mui/material';
import {
  ChevronDown,
  ChevronRight,
  Plus,
  Edit2,
  Trash2,
  Layout,
  Layers,
  Zap
} from 'lucide-react';

interface Feature {
  id: string;
  name: string;
  description: string;
  type: 'feature' | 'subfeature' | 'action';
  children?: Feature[];
}

// Updated mock data with the new structure
const mockFeatures: Feature[] = [
  {
    id: '1',
    name: 'Dashboard',
    description: 'Main dashboard functionality',
    type: 'feature',
    children: [
      {
        id: '1-1',
        name: 'Analytics',
        description: 'Analytics management',
        type: 'subfeature',
        children: [
          {
            id: '1-1-1',
            name: 'Upload',
            description: 'Upload analytics data',
            type: 'action'
          },
          {
            id: '1-1-2',
            name: 'Create',
            description: 'Create new analytics',
            type: 'action'
          },
          {
            id: '1-1-3',
            name: 'Delete',
            description: 'Delete analytics data',
            type: 'action'
          }
        ]
      },
      {
        id: '1-2',
        name: 'Metrics',
        description: 'Metrics management',
        type: 'subfeature',
        children: []
      },
      {
        id: '1-3',
        name: 'Export data',
        description: 'Export dashboard data',
        type: 'action'
      },
      {
        id: '1-4',
        name: 'Mark Scan',
        description: 'Mark scan completion',
        type: 'action'
      }
    ]
  },
  {
    id: '2',
    name: 'Release Management',
    description: 'Manage software releases',
    type: 'feature',
    children: [
      {
        id: '2-1',
        name: 'Release Event',
        description: 'Manage release events',
        type: 'subfeature',
        children: [
          {
            id: '2-1-1',
            name: 'Upload',
            description: 'Upload release files',
            type: 'action'
          },
          {
            id: '2-1-2',
            name: 'Create',
            description: 'Create new release',
            type: 'action'
          },
          {
            id: '2-1-3',
            name: 'Delete',
            description: 'Delete release',
            type: 'action'
          }
        ]
      }
    ]
  }
];

export default function Features() {
  const [features, setFeatures] = useState<Feature[]>(mockFeatures);
  const [expandedFeatures, setExpandedFeatures] = useState<Set<string>>(new Set(['1', '2']));
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [editingFeature, setEditingFeature] = useState<Feature | null>(null);
  const [parentFeature, setParentFeature] = useState<Feature | null>(null);
  const [formData, setFormData] = useState({
    name: '',
    description: '',
    type: 'feature' as const
  });

  const toggleExpand = (id: string) => {
    setExpandedFeatures(prev => {
      const next = new Set(prev);
      if (next.has(id)) {
        next.delete(id);
      } else {
        next.add(id);
      }
      return next;
    });
  };

  const handleDelete = (feature: Feature, parent: Feature | null = null) => {
    if (!window.confirm('Are you sure you want to delete this item?')) return;

    if (!parent) {
      setFeatures(prev => prev.filter(f => f.id !== feature.id));
    } else {
      const updateChildren = (items: Feature[]): Feature[] => {
        return items.map(item => {
          if (item.id === parent.id) {
            return {
              ...item,
              children: item.children?.filter(child => child.id !== feature.id)
            };
          }
          if (item.children) {
            return {
              ...item,
              children: updateChildren(item.children)
            };
          }
          return item;
        });
      };
      setFeatures(prev => updateChildren(prev));
    }
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    const newFeature: Feature = {
      id: Math.random().toString(36).substr(2, 9),
      ...formData
    };

    if (editingFeature) {
      const updateFeature = (items: Feature[]): Feature[] => {
        return items.map(item => {
          if (item.id === editingFeature.id) {
            return { ...item, ...formData };
          }
          if (item.children) {
            return {
              ...item,
              children: updateFeature(item.children)
            };
          }
          return item;
        });
      };
      setFeatures(prev => updateFeature(prev));
    } else if (parentFeature) {
      const addChild = (items: Feature[]): Feature[] => {
        return items.map(item => {
          if (item.id === parentFeature.id) {
            return {
              ...item,
              children: [...(item.children || []), newFeature]
            };
          }
          if (item.children) {
            return {
              ...item,
              children: addChild(item.children)
            };
          }
          return item;
        });
      };
      setFeatures(prev => addChild(prev));
    } else {
      setFeatures(prev => [...prev, newFeature]);
    }

    setIsModalOpen(false);
    setEditingFeature(null);
    setParentFeature(null);
    setFormData({ name: '', description: '', type: 'feature' });
  };

  const getTypeIcon = (type: string) => {
    switch (type) {
      case 'feature':
        return <Layout size={20} />;
      case 'subfeature':
        return <Layers size={20} />;
      case 'action':
        return <Zap size={20} />;
      default:
        return null;
    }
  };

  const getTypeColor = (type: string) => {
    switch (type) {
      case 'feature':
        return '#1976d2';
      case 'subfeature':
        return '#2e7d32';
      case 'action':
        return '#ed6c02';
      default:
        return '#757575';
    }
  };

  const renderFeatureTree = (feature: Feature, level = 0, parent: Feature | null = null) => {
    const isExpanded = expandedFeatures.has(feature.id);
    const hasChildren = feature.children && feature.children.length > 0;
    const color = getTypeColor(feature.type);
    
    return (
      <Box key={feature.id}>
        <ListItem
          sx={{
            pl: level * 4,
            borderLeft: level > 0 ? `1px dashed ${color}` : 'none',
            '&:hover': {
              bgcolor: 'rgba(0, 0, 0, 0.04)'
            }
          }}
        >
          <ListItemIcon sx={{ minWidth: 32 }}>
            {(hasChildren || feature.type !== 'action') && (
              <IconButton
                size="small"
                onClick={() => toggleExpand(feature.id)}
                sx={{ mr: 1 }}
              >
                {isExpanded ? <ChevronDown size={16} /> : <ChevronRight size={16} />}
              </IconButton>
            )}
          </ListItemIcon>
          <ListItemIcon sx={{ color }}>
            {getTypeIcon(feature.type)}
          </ListItemIcon>
          <ListItemText
            primary={feature.name}
            secondary={feature.description}
            primaryTypographyProps={{
              sx: { color, fontWeight: feature.type === 'feature' ? 600 : 400 }
            }}
          />
          <ListItemSecondaryAction>
            {feature.type !== 'action' && (
              <IconButton
                size="small"
                onClick={() => {
                  setEditingFeature(null);
                  setParentFeature(feature);
                  setFormData({
                    name: '',
                    description: '',
                    type: feature.type === 'feature' ? 'subfeature' : 'action'
                  });
                  setIsModalOpen(true);
                }}
                sx={{ mr: 1 }}
              >
                <Plus size={16} />
              </IconButton>
            )}
            <IconButton
              size="small"
              onClick={() => {
                setEditingFeature(feature);
                setParentFeature(parent);
                setFormData({
                  name: feature.name,
                  description: feature.description,
                  type: feature.type
                });
                setIsModalOpen(true);
              }}
              sx={{ mr: 1 }}
            >
              <Edit2 size={16} />
            </IconButton>
            <IconButton 
              size="small" 
              color="error"
              onClick={() => handleDelete(feature, parent)}
            >
              <Trash2 size={16} />
            </IconButton>
          </ListItemSecondaryAction>
        </ListItem>
        {hasChildren && isExpanded && (
          <List disablePadding>
            {feature.children?.map(child => renderFeatureTree(child, level + 1, feature))}
          </List>
        )}
      </Box>
    );
  };

  return (
    <Box sx={{ p: 3 }}>
      <Box display="flex" justifyContent="space-between" alignItems="center" mb={3}>
        <Typography variant="h4" component="h1">
          Features Management
        </Typography>
        <Button
          variant="contained"
          startIcon={<Plus size={20} />}
          onClick={() => {
            setEditingFeature(null);
            setParentFeature(null);
            setFormData({ name: '', description: '', type: 'feature' });
            setIsModalOpen(true);
          }}
        >
          Add Feature
        </Button>
      </Box>

      <Paper elevation={0} sx={{ bgcolor: 'background.paper' }}>
        <List>
          {features.map(feature => renderFeatureTree(feature))}
        </List>
      </Paper>

      <Dialog open={isModalOpen} onClose={() => setIsModalOpen(false)} maxWidth="sm" fullWidth>
        <form onSubmit={handleSubmit}>
          <DialogTitle>
            {editingFeature ? 'Edit Item' : `Add ${formData.type.charAt(0).toUpperCase() + formData.type.slice(1)}`}
          </DialogTitle>
          <DialogContent>
            <Stack spacing={2} sx={{ mt: 2 }}>
              <TextField
                label="Name"
                value={formData.name}
                onChange={(e) => setFormData({ ...formData, name: e.target.value })}
                fullWidth
                required
              />
              <TextField
                label="Description"
                value={formData.description}
                onChange={(e) => setFormData({ ...formData, description: e.target.value })}
                fullWidth
                multiline
                rows={3}
              />
              <FormControl fullWidth>
                <InputLabel>Type</InputLabel>
                <Select
                  value={formData.type}
                  label="Type"
                  onChange={(e) => setFormData({ ...formData, type: e.target.value as 'feature' | 'subfeature' | 'action' })}
                  disabled={!!parentFeature}
                >
                  <MenuItem value="feature">Feature</MenuItem>
                  <MenuItem value="subfeature">Subfeature</MenuItem>
                  <MenuItem value="action">Action</MenuItem>
                </Select>
              </FormControl>
            </Stack>
          </DialogContent>
          <DialogActions>
            <Button onClick={() => setIsModalOpen(false)}>Cancel</Button>
            <Button type="submit" variant="contained">
              {editingFeature ? 'Update' : 'Create'}
            </Button>
          </DialogActions>
        </form>
      </Dialog>
    </Box>
  );
}
