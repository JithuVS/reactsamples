import React, { useState } from 'react';
import {
  Box,
  Typography,
  IconButton,
  Button,
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  TextField,
  Select,
  MenuItem,
  FormControl,
  InputLabel,
  Switch,
  FormControlLabel,
  Stack,
  List,
  ListItem,
  Paper,
  Chip,
  Tooltip
} from '@mui/material';
import {
  ChevronDown,
  ChevronRight,
  Plus,
  Edit2,
  Trash2,
  Shield,
  Settings,
  Key,
  Zap,
  Layers,
  AlertCircle,
  Layout,
  Database,
  Search
} from 'lucide-react';
import type { Feature, SubFeature, ChildFeature, FeaturePermission } from '../types';

const initialData: Feature[] = [
  {
    feature: "Vulnerability Management",
    featureDescription: null,
    featurePermissions: "VIEW",
    featureVisibility: true,
    allowedFeatureActions: {},
    subFeatures: [
      {
        subFeature: "Dashboard",
        subFeatureDescription: null,
        subFeaturePermissions: "VIEW",
        subFeatureVisibility: true,
        allowedSubFeatureActions: {
          view: true,
          lobwidgets: false,
        },
        childFeatures: []
      },
      {
        subFeature: "Black Duck",
        subFeatureDescription: null,
        subFeaturePermissions: "VIEW",
        subFeatureVisibility: true,
        allowedSubFeatureActions: {
          view: true,
          markforupload: false,
          downloadscan: false,
        },
        childFeatures: []
      },
      {
        subFeature: "Checkmarx",
        subFeatureDescription: null,
        subFeaturePermissions: "VIEW",
        subFeatureVisibility: true,
        allowedSubFeatureActions: {
          view: true,
          markforupload: false,
          downloadscan: false,
          createproject: true,
        },
        childFeatures: []
      },
    ],
  },
];

interface DialogState {
  open: boolean;
  type: 'feature' | 'subfeature' | 'childfeature' | null;
  mode: 'add' | 'edit' | null;
  parentFeature?: Feature;
  parentSubFeature?: SubFeature;
  item?: Feature | SubFeature | ChildFeature;
}

const getFeatureIcon = (name: string) => {
  const iconProps = { size: 20 };
  
  if (name.toLowerCase().includes('dashboard')) return <Layout {...iconProps} />;
  if (name.toLowerCase().includes('security')) return <Shield {...iconProps} />;
  if (name.toLowerCase().includes('management')) return <Settings {...iconProps} />;
  if (name.toLowerCase().includes('data')) return <Database {...iconProps} />;
  if (name.toLowerCase().includes('search')) return <Search {...iconProps} />;
  
  return <Settings {...iconProps} />;
};

export default function Features() {
  const [features, setFeatures] = useState<Feature[]>(initialData);
  const [expandedItems, setExpandedItems] = useState<Set<string>>(new Set());
  const [expandedSubItems, setExpandedSubItems] = useState<Set<string>>(new Set());
  const [dialog, setDialog] = useState<DialogState>({ open: false, type: null, mode: null });
  const [formData, setFormData] = useState({
    name: '',
    description: null as string | null,
    permissions: 'VIEW' as FeaturePermission,
    visibility: true,
    actions: {} as Record<string, boolean>
  });
  const [newAction, setNewAction] = useState('');

  const toggleExpand = (itemName: string, isSubFeature: boolean = false) => {
    const setterFunction = isSubFeature ? setExpandedSubItems : setExpandedItems;
    setterFunction(prev => {
      const next = new Set(prev);
      if (next.has(itemName)) {
        next.delete(itemName);
      } else {
        next.add(itemName);
      }
      return next;
    });
  };

  const handleOpenDialog = (
    type: 'feature' | 'subfeature' | 'childfeature',
    mode: 'add' | 'edit',
    parentFeature?: Feature,
    parentSubFeature?: SubFeature,
    item?: Feature | SubFeature | ChildFeature
  ) => {
    setDialog({ open: true, type, mode, parentFeature, parentSubFeature, item });
    if (mode === 'edit' && item) {
      setFormData({
        name: 'feature' in item ? item.feature : 
             'subFeature' in item ? item.subFeature : 
             item.childFeature,
        description: 'featureDescription' in item ? item.featureDescription :
                    'subFeatureDescription' in item ? item.subFeatureDescription :
                    item.childFeatureDescription,
        permissions: 'featurePermissions' in item ? item.featurePermissions :
                    'subFeaturePermissions' in item ? item.subFeaturePermissions :
                    item.childFeaturePermissions,
        visibility: 'featureVisibility' in item ? item.featureVisibility :
                   'subFeatureVisibility' in item ? item.subFeatureVisibility :
                   item.childFeatureVisibility,
        actions: 'allowedFeatureActions' in item ? item.allowedFeatureActions :
                'allowedSubFeatureActions' in item ? item.allowedSubFeatureActions :
                item.allowedChildFeatureActions
      });
    } else {
      setFormData({
        name: '',
        description: null,
        permissions: 'VIEW',
        visibility: true,
        actions: {}
      });
    }
  };

  const handleCloseDialog = () => {
    setDialog({ open: false, type: null, mode: null });
    setFormData({
      name: '',
      description: null,
      permissions: 'VIEW',
      visibility: true,
      actions: {}
    });
    setNewAction('');
  };

  const handleAddAction = () => {
    if (newAction.trim()) {
      setFormData(prev => ({
        ...prev,
        actions: {
          ...prev.actions,
          [newAction.toLowerCase()]: false
        }
      }));
      setNewAction('');
    }
  };

  const handleToggleAction = (action: string) => {
    setFormData(prev => ({
      ...prev,
      actions: {
        ...prev.actions,
        [action]: !prev.actions[action]
      }
    }));
  };

  const handleRemoveAction = (action: string) => {
    const { [action]: _, ...remainingActions } = formData.actions;
    setFormData(prev => ({
      ...prev,
      actions: remainingActions
    }));
  };

  const handleSave = (e: React.FormEvent) => {
    e.preventDefault();
    
    if (dialog.mode === 'add') {
      if (dialog.type === 'feature') {
        const newFeature: Feature = {
          feature: formData.name,
          featureDescription: formData.description,
          featurePermissions: formData.permissions,
          featureVisibility: formData.visibility,
          allowedFeatureActions: formData.actions,
          subFeatures: []
        };
        setFeatures(prev => [...prev, newFeature]);
      } else if (dialog.type === 'subfeature' && dialog.parentFeature) {
        const newSubFeature: SubFeature = {
          subFeature: formData.name,
          subFeatureDescription: formData.description,
          subFeaturePermissions: formData.permissions,
          subFeatureVisibility: formData.visibility,
          allowedSubFeatureActions: formData.actions,
          childFeatures: []
        };
        setFeatures(prev =>
          prev.map(feature =>
            feature === dialog.parentFeature
              ? { ...feature, subFeatures: [...feature.subFeatures, newSubFeature] }
              : feature
          )
        );
      } else if (dialog.type === 'childfeature' && dialog.parentFeature && dialog.parentSubFeature) {
        const newChildFeature: ChildFeature = {
          childFeature: formData.name,
          childFeatureDescription: formData.description,
          childFeaturePermissions: formData.permissions,
          childFeatureVisibility: formData.visibility,
          allowedChildFeatureActions: formData.actions
        };
        setFeatures(prev =>
          prev.map(feature =>
            feature === dialog.parentFeature
              ? {
                  ...feature,
                  subFeatures: feature.subFeatures.map(subFeature =>
                    subFeature === dialog.parentSubFeature
                      ? {
                          ...subFeature,
                          childFeatures: [...subFeature.childFeatures, newChildFeature]
                        }
                      : subFeature
                  )
                }
              : feature
          )
        );
      }
    } else if (dialog.mode === 'edit' && dialog.item) {
      if (dialog.type === 'feature') {
        setFeatures(prev =>
          prev.map(feature =>
            feature === dialog.item
              ? {
                  ...feature,
                  feature: formData.name,
                  featureDescription: formData.description,
                  featurePermissions: formData.permissions,
                  featureVisibility: formData.visibility,
                  allowedFeatureActions: formData.actions
                }
              : feature
          )
        );
      } else if (dialog.type === 'subfeature' && dialog.parentFeature) {
        setFeatures(prev =>
          prev.map(feature =>
            feature === dialog.parentFeature
              ? {
                  ...feature,
                  subFeatures: feature.subFeatures.map(subFeature =>
                    subFeature === dialog.item
                      ? {
                          ...subFeature,
                          subFeature: formData.name,
                          subFeatureDescription: formData.description,
                          subFeaturePermissions: formData.permissions,
                          subFeatureVisibility: formData.visibility,
                          allowedSubFeatureActions: formData.actions
                        }
                      : subFeature
                  )
                }
              : feature
          )
        );
      } else if (dialog.type === 'childfeature' && dialog.parentFeature && dialog.parentSubFeature) {
        setFeatures(prev =>
          prev.map(feature =>
            feature === dialog.parentFeature
              ? {
                  ...feature,
                  subFeatures: feature.subFeatures.map(subFeature =>
                    subFeature === dialog.parentSubFeature
                      ? {
                          ...subFeature,
                          childFeatures: subFeature.childFeatures.map(childFeature =>
                            childFeature === dialog.item
                              ? {
                                  ...childFeature,
                                  childFeature: formData.name,
                                  childFeatureDescription: formData.description,
                                  childFeaturePermissions: formData.permissions,
                                  childFeatureVisibility: formData.visibility,
                                  allowedChildFeatureActions: formData.actions
                                }
                              : childFeature
                          )
                        }
                      : subFeature
                  )
                }
              : feature
          )
        );
      }
    }
    handleCloseDialog();
  };

  const handleDelete = (
    type: 'feature' | 'subfeature' | 'childfeature',
    item: Feature | SubFeature | ChildFeature,
    parentFeature?: Feature,
    parentSubFeature?: SubFeature
  ) => {
    if (!window.confirm('Are you sure you want to delete this item?')) return;

    if (type === 'feature') {
      setFeatures(prev => prev.filter(feature => feature !== item));
    } else if (type === 'subfeature' && parentFeature) {
      setFeatures(prev =>
        prev.map(feature =>
          feature === parentFeature
            ? {
                ...feature,
                subFeatures: feature.subFeatures.filter(subFeature => subFeature !== item)
              }
            : feature
        )
      );
    } else if (type === 'childfeature' && parentFeature && parentSubFeature) {
      setFeatures(prev =>
        prev.map(feature =>
          feature === parentFeature
            ? {
                ...feature,
                subFeatures: feature.subFeatures.map(subFeature =>
                  subFeature === parentSubFeature
                    ? {
                        ...subFeature,
                        childFeatures: subFeature.childFeatures.filter(
                          childFeature => childFeature !== item
                        )
                      }
                    : subFeature
                )
              }
            : feature
        )
      );
    }
  };

  const renderChildFeature = (childFeature: ChildFeature, parentFeature: Feature, parentSubFeature: SubFeature) => {
    const icon = getFeatureIcon(childFeature.childFeature);

    return (
      <ListItem
        key={childFeature.childFeature}
        sx={{
          pl: 10,
          pr: 2,
          py: 1,
          display: 'flex',
          alignItems: 'center',
          gap: 2,
          '&:hover': {
            bgcolor: 'action.hover',
          },
          position: 'relative',
          '&::before': {
            content: '""',
            position: 'absolute',
            left: 64,
            top: '50%',
            width: 16,
            height: 1,
            bgcolor: 'divider'
          }
        }}
      >
        <Box sx={{ color: 'success.main' }}>{icon}</Box>
        <Box sx={{ flex: 1 }}>
          <Typography variant="body2" sx={{ fontWeight: 500 }}>
            {childFeature.childFeature}
          </Typography>
          {childFeature.childFeatureDescription && (
            <Typography variant="caption" color="text.secondary">
              {childFeature.childFeatureDescription}
            </Typography>
          )}
          <Stack direction="row" spacing={1} sx={{ mt: 0.5 }}>
            <Chip
              size="small"
              icon={<Key size={14} />}
              label={childFeature.childFeaturePermissions}
              color="primary"
              variant="outlined"
            />
            {Object.entries(childFeature.allowedChildFeatureActions).map(([action, enabled]) => (
              <Chip
                key={action}
                size="small"
                icon={<Zap size={14} />}
                label={action}
                color={enabled ? "success" : "default"}
                variant="outlined"
              />
            ))}
            {!childFeature.childFeatureVisibility && (
              <Chip
                size="small"
                icon={<AlertCircle size={14} />}
                label="Hidden"
                color="warning"
                variant="outlined"
              />
            )}
          </Stack>
        </Box>
        <Box sx={{ display: 'flex', gap: 1 }}>
          <Tooltip title="Edit">
            <IconButton
              size="small"
              onClick={() => handleOpenDialog('childfeature', 'edit', parentFeature, parentSubFeature, childFeature)}
            >
              <Edit2 size={16} />
            </IconButton>
          </Tooltip>
          <Tooltip title="Delete">
            <IconButton
              size="small"
              color="error"
              onClick={() => handleDelete('childfeature', childFeature, parentFeature, parentSubFeature)}
            >
              <Trash2 size={16} />
            </IconButton>
          </Tooltip>
        </Box>
      </ListItem>
    );
  };

  const renderSubFeature = (subFeature: SubFeature, parentFeature: Feature) => {
    const icon = getFeatureIcon(subFeature.subFeature);
    const isExpanded = expandedSubItems.has(subFeature.subFeature);

    return (
      <Box key={subFeature.subFeature}>
        <ListItem
          sx={{
            pl: 6,
            pr: 2,
            py: 1,
            display: 'flex',
            alignItems: 'center',
            gap: 2,
            '&:hover': {
              bgcolor: 'action.hover',
            },
            position: 'relative',
            '&::before': {
              content: '""',
              position: 'absolute',
              left: 32,
              top: '50%',
              width: 16,
              height: 1,
              bgcolor: 'divider'
            }
          }}
        >
          <Box
            sx={{
              display: 'flex',
              alignItems: 'center',
              gap: 2,
              flex: 1,
              cursor: 'pointer'
            }}
            onClick={() => toggleExpand(subFeature.subFeature, true)}
          >
            <IconButton size="small" sx={{ p: 0.5 }}>
              {isExpanded ? <ChevronDown size={20} /> : <ChevronRight size={20} />}
            </IconButton>
            <Box sx={{ color: 'primary.main' }}>{icon}</Box>
            <Box sx={{ flex: 1 }}>
              <Typography variant="body2" sx={{ fontWeight: 500 }}>
                {subFeature.subFeature}
              </Typography>
              {subFeature.subFeatureDescription && (
                <Typography variant="caption" color="text.secondary">
                  {subFeature.subFeatureDescription}
                </Typography>
              )}
              <Stack direction="row" spacing={1} sx={{ mt: 0.5 }}>
                <Chip
                  size="small"
                  icon={<Key size={14} />}
                  label={subFeature.subFeaturePermissions}
                  color="primary"
                  variant="outlined"
                />
                {Object.entries(subFeature.allowedSubFeatureActions).map(([action, enabled]) => (
                  <Chip
                    key={action}
                    size="small"
                    icon={<Zap size={14} />}
                    label={action}
                    color={enabled ? "success" : "default"}
                    variant="outlined"
                  />
                ))}
                {!subFeature.subFeatureVisibility && (
                  <Chip
                    size="small"
                    icon={<AlertCircle size={14} />}
                    label="Hidden"
                    color="warning"
                    variant="outlined"
                  />
                )}
              </Stack>
            </Box>
          </Box>
          <Box sx={{ display: 'flex', gap: 1 }}>
            <Tooltip title="Add Child Feature">
              <IconButton
                size="small"
                onClick={() => handleOpenDialog('childfeature', 'add', parentFeature, subFeature)}
              >
                <Plus size={16} />
              </IconButton>
            </Tooltip>
            <Tooltip title="Edit">
              <IconButton
                size="small"
                onClick={() => handleOpenDialog('subfeature', 'edit', parentFeature, undefined, subFeature)}
              >
                <Edit2 size={16} />
              </IconButton>
            </Tooltip>
            <Tooltip title="Delete">
              <IconButton
                size="small"
                color="error"
                onClick={() => handleDelete('subfeature', subFeature, parentFeature)}
              >
                <Trash2 size={16} />
              </IconButton>
            </Tooltip>
          </Box>
        </ListItem>

        {isExpanded && (
          <>
            <List disablePadding>
              {subFeature.childFeatures.map(childFeature =>
                renderChildFeature(childFeature, parentFeature, subFeature)
              )}
            </List>
            <Box sx={{ pl: 10, pr: 2, py: 1 }}>
              <Button
                startIcon={<Layers size={16} />}
                onClick={() => handleOpenDialog('childfeature', 'add', parentFeature, subFeature)}
                size="small"
                variant="outlined"
              >
                Add Child Feature
              </Button>
            </Box>
          </>
        )}
      </Box>
    );
  };

  const renderFeature = (feature: Feature) => {
    const isExpanded = expandedItems.has(feature.feature);
    const icon = getFeatureIcon(feature.feature);

    return (
      <Box key={feature.feature}>
        <ListItem
          sx={{
            py: 1,
            px: 2,
            '&:hover': {
              bgcolor: 'action.hover',
            }
          }}
        >
          <Box
            sx={{
              display: 'flex',
              alignItems: 'center',
              gap: 2,
              flex: 1,
              cursor: 'pointer'
            }}
            onClick={() => toggleExpand(feature.feature)}
          >
            <IconButton size="small" sx={{ p: 0.5 }}>
              {isExpanded ? <ChevronDown size={20} /> : <ChevronRight size={20} />}
            </IconButton>
            <Box sx={{ color: 'primary.main' }}>{icon}</Box>
            <Box sx={{ flex: 1 }}>
              <Typography variant="subtitle1" sx={{ fontWeight: 500 }}>
                {feature.feature}
              </Typography>
              {feature.featureDescription && (
                <Typography variant="caption" color="text.secondary">
                  {feature.featureDescription}
                </Typography>
              )}
              <Stack direction="row" spacing={1} sx={{ mt: 0.5 }}>
                <Chip
                  size="small"
                  icon={<Key size={14} />}
                  label={feature.featurePermissions}
                  color="primary"
                  variant="outlined"
                />
                {Object.entries(feature.allowedFeatureActions).map(([action, enabled]) => (
                  <Chip
                    key={action}
                    size="small"
                    icon={<Zap size={14} />}
                    label={action}
                    color={enabled ? "success" : "default"}
                    variant="outlined"
                  />
                ))}
                {!feature.featureVisibility && (
                  <Chip
                    size="small"
                    icon={<AlertCircle size={14} />}
                    label="Hidden"
                    color="warning"
                    variant="outlined"
                  />
                )}
              </Stack>
            </Box>
          </Box>
          <Box sx={{ display: 'flex', gap: 1 }}>
            <Tooltip title="Add Subfeature">
              <IconButton
                size="small"
                onClick={() => handleOpenDialog('subfeature', 'add', feature)}
              >
                <Plus size={16} />
              </IconButton>
            </Tooltip>
            <Tooltip title="Edit">
              <IconButton
                size="small"
                onClick={() => handleOpenDialog('feature', 'edit', undefined, undefined, feature)}
              >
                <Edit2 size={16} />
              </IconButton>
            </Tooltip>
            <Tooltip title="Delete">
              <IconButton
                size="small"
                color="error"
                onClick={() => handleDelete('feature', feature)}
              >
                <Trash2 size={16} />
              </IconButton>
            </Tooltip>
          </Box>
        </ListItem>
        
        {isExpanded && (
          <List disablePadding>
            {feature.subFeatures.map(subFeature => 
              renderSubFeature(subFeature, feature)
            )}
          </List>
        )}
      </Box>
    );
  };

  return (
    <Box sx={{ p: 3 }}>
      <Box display="flex" justifyContent="space-between" alignItems="center" mb={3}>
        <Typography variant="h4" component="h1" sx={{ fontWeight: 500 }}>
          Features Management
        </Typography>
        <Button
          variant="contained"
          startIcon={<Plus size={20} />}
          onClick={() => handleOpenDialog('feature', 'add')}
        >
          Add Feature
        </Button>
      </Box>

      <Paper 
        elevation={0} 
        sx={{ 
          bgcolor: 'background.paper',
          border: '1px solid',
          borderColor: 'divider',
          borderRadius: 1
        }}
      >
        <List disablePadding>
          {features.map(renderFeature)}
        </List>
      </Paper>

      <Dialog open={dialog.open} onClose={handleCloseDialog} maxWidth="sm" fullWidth>
        <form onSubmit={handleSave}>
          <DialogTitle>
            {dialog.mode === 'add' ? 'Add' : 'Edit'} {
              dialog.type === 'feature' ? 'Feature' :
              dialog.type === 'subfeature' ? 'Subfeature' :
              'Child Feature'
            }
          </DialogTitle>
          <DialogContent>
            <Stack spacing={2} sx={{ mt: 2 }}>
              <TextField
                label="Name"
                value={formData.name}
                onChange={(e) => setFormData(prev => ({ ...prev, name: e.target.value }))}
                fullWidth
                required
              />
              <TextField
                label="Description"
                value={formData.description || ''}
                onChange={(e) => setFormData(prev => ({ ...prev, description: e.target.value || null }))}
                fullWidth
                multiline
                rows={3}
              />
              <FormControl fullWidth>
                <InputLabel>Permissions</InputLabel>
                <Select
                  value={formData.permissions}
                  label="Permissions"
                  onChange={(e) => setFormData(prev => ({ ...prev, permissions: e.target.value as FeaturePermission }))}
                >
                  <MenuItem value="VIEW">View</MenuItem>
                  <MenuItem value="EDIT">Edit</MenuItem>
                  <MenuItem value="ADMIN">Admin</MenuItem>
                </Select>
              </FormControl>
              <FormControlLabel
                control={
                  <Switch
                    checked={formData.visibility}
                    onChange={(e) => setFormData(prev => ({ ...prev, visibility: e.target.checked }))}
                  />
                }
                label="Visibility"
              />
              <Box>
                <Box display="flex" justifyContent="space-between" alignItems="center" mb={1}>
                  <Typography variant="subtitle2">Actions</Typography>
                  <TextField
                    size="small"
                    placeholder="New action name"
                    value={newAction}
                    onChange={(e) => setNewAction(e.target.value)}
                    sx={{ mr: 1 }}
                  />
                  <Button
                    size="small"
                    variant="outlined"
                    startIcon={<Plus size={16} />}
                    onClick={handleAddAction}
                    disabled={!newAction.trim()}
                  >
                    Add
                  </Button>
                </Box>
                <Stack direction="row" spacing={1} flexWrap="wrap" useFlexGap>
                  {Object.entries(formData.actions).map(([action, enabled]) => (
                    <Chip
                      key={action}
                      label={action}
                      icon={<Zap size={14} />}
                      color={enabled ? "success" : "default"}
                      variant={enabled ? "filled" : "outlined"}
                      onClick={() => handleToggleAction(action)}
                      onDelete={() => handleRemoveAction(action)}
                    />
                  ))}
                </Stack>
              </Box>
            </Stack>
          </DialogContent>
          <DialogActions>
            <Button onClick={handleCloseDialog}>Cancel</Button>
            <Button type="submit" variant="contained">
              {dialog.mode === 'add' ? 'Create' : 'Update'}
            </Button>
          </DialogActions>
        </form>
      </Dialog>
    </Box>
  );
}
